# === 必填：DeepSeek API（国内手机号注册，新用户送免费额度） ===
# 注册地址：https://platform.deepseek.com
# 注册后在 API Keys 页面创建一个 key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 必填：邮箱 SMTP（免费） ===
# QQ邮箱: smtp.qq.com, 端口 465
# 163邮箱: smtp.163.com, 端口 465
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SENDER_EMAIL=你的QQ邮箱@qq.com
# 授权码，不是登录密码！QQ邮箱设置 → 账户 → POP3/SMTP服务 → 获取授权码
SENDER_PASSWORD=你的邮箱授权码
RECEIVER_EMAIL=接收推送的邮箱@qq.com

# === 可选 ===
DEEPSEEK_MODEL=deepseek-chat
NEWS_COUNT=2
CONCEPT_COUNT=2
MAX_RETRIES=3
PUSH_TIME=08:00
